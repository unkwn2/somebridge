<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Widget.Button.Tonal" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/btn_tonal_selector</item>
        <item name="android:textColor">#C9D1D9</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Widget.Button.Outlined" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/btn_outlined_selector</item>
        <item name="android:textColor">#C9D1D9</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Widget.Button.Red" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/btn_red_selector</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
</resources>