<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="YandexHUD"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#C9D1D9" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Activation Required"
        android:textSize="14sp"
        android:textColor="#8B949E" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Your Public Key (send this to developer):"
        android:textSize="12sp"
        android:textColor="#8B949E" />

    <TextView
        android:id="@+id/deviceIdText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:padding="12dp"
        android:background="#161B22"
        android:textSize="9sp"
        android:fontFamily="monospace"
        android:textColor="#C9D1D9"
        android:textIsSelectable="true"
        android:gravity="center" />

    <Button
        android:id="@+id/copyDeviceId"
        style="@style/Widget.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:text="COPY PUBLIC KEY"
        android:textSize="11sp"
        android:textAllCaps="false" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="License Key:"
        android:textSize="12sp"
        android:textColor="#8B949E" />

    <EditText
        android:id="@+id/licenseInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:padding="12dp"
        android:background="#161B22"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:textColor="#C9D1D9"
        android:hint="Paste license key here"
        android:inputType="textMultiLine"
        android:lines="3"
        android:gravity="top" />

    <Button
        android:id="@+id/btnActivate"
        style="@style/Widget.Button.Tonal"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:text="ACTIVATE"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textAllCaps="false" />

</LinearLayout>