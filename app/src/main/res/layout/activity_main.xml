<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117"
    android:padding="12dp">

    <!-- STATUS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_shape"
        android:padding="12dp">

        <TextView
            android:id="@+id/statusBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Y:OFF FGS:false | idle | A11y:OFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#C9D1D9" />
    </LinearLayout>

    <!-- SERVICES -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/card_shape"
        android:padding="10dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnYandex"
                style="@style/Widget.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="YANDEX NAVI"
                android:textSize="11sp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnMockGps"
                style="@style/Widget.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="MOCK GPS"
                android:textSize="11sp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnSniffer"
                style="@style/Widget.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="SNIFFER"
                android:textSize="11sp"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnNotifAccess"
                style="@style/Widget.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="NOTIF"
                android:textSize="11sp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnA11y"
                style="@style/Widget.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="A11Y"
                android:textSize="11sp"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- TEST -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/card_shape"
        android:padding="10dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTestLeft"
                style="@style/Widget.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="LEFT"
                android:textSize="11sp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnDumpTree"
                style="@style/Widget.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="DUMP"
                android:textSize="11sp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnIconScan"
                style="@style/Widget.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="ICON: OFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPngIcon"
                style="@style/Widget.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="PNG: OFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnTestLanes"
                style="@style/Widget.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="LANES"
                android:textSize="11sp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnTestNextNext"
                style="@style/Widget.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="NEXT+NEXT"
                android:textSize="11sp"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTestNavMap"
                style="@style/Widget.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="NAVMAP"
                android:textSize="11sp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnArrowScan"
                style="@style/Widget.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="ARROW SCAN"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- SETTINGS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/card_shape"
        android:padding="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnTogglePacked"
            style="@style/Widget.Button.Tonal"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="PACKED"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnHudMode"
            style="@style/Widget.Button.Tonal"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="HUD MODE"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnGrant"
            style="@style/Widget.Button.Tonal"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="GRANT"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnSaveLog"
            style="@style/Widget.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="SAVE LOG"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnRvDump"
            style="@style/Widget.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="RV: OFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="false" />
    </LinearLayout>

    <!-- LOG -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:background="@drawable/card_shape_log"
        android:padding="4dp">

        <ScrollView
            android:id="@+id/logScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/logText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:textColor="#7EE787"
                android:lineSpacingExtra="2dp" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>