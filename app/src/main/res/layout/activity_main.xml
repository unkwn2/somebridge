<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117"
    android:padding="14dp">

    <!-- Статус -->
    <TextView
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#161B22"
        android:padding="10dp"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:textColor="#58A6FF"
        android:text="Y:OFF FGS:false | idle | NEW | A11y:OFF" />

    <!-- Главная кнопка -->
    <Button
        android:id="@+id/btnYandex"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="12dp"
        android:text="YANDEX NAVI"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:backgroundTint="#238636" />

    <!-- Меню -->
    <Button
        android:id="@+id/btnMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="MENU"
        android:textAllCaps="false"
        android:textColor="#C9D1D9"
        android:backgroundTint="#21262D" />

    <!-- Скрытая панель -->
    <LinearLayout
        android:id="@+id/hiddenPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="НАСТРОЙКИ" android:textColor="#8B949E" android:textSize="11sp"
            android:textStyle="bold" android:paddingTop="6dp" android:paddingBottom="2dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnSpeedSign" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="ЗНАК СК: ВКЛ" android:textAllCaps="false"
                android:textColor="#C9D1D9" android:backgroundTint="#21262D" android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/btnLogs" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="LOGS: OFF" android:textAllCaps="false"
                android:textColor="#C9D1D9" android:backgroundTint="#21262D" android:layout_marginStart="4dp"/>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="ДОСТУП" android:textColor="#8B949E" android:textSize="11sp"
            android:textStyle="bold" android:paddingTop="10dp" android:paddingBottom="2dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnA11y" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="A11Y" android:textAllCaps="false"
                android:textColor="#C9D1D9" android:backgroundTint="#21262D" android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/btnGrant" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="ПРАВА" android:textAllCaps="false"
                android:textColor="#C9D1D9" android:backgroundTint="#21262D" android:layout_marginStart="4dp"/>
        </LinearLayout>
        <Button android:id="@+id/btnNotifAccess" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="ДОСТУП К УВЕДОМЛЕНИЯМ" android:textAllCaps="false"
            android:textColor="#C9D1D9" android:backgroundTint="#21262D" android:layout_marginTop="8dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="ДИАГНОСТИКА" android:textColor="#8B949E" android:textSize="11sp"
            android:textStyle="bold" android:paddingTop="10dp" android:paddingBottom="2dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnRvDump" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="RV: OFF" android:textAllCaps="false"
                android:textColor="#C9D1D9" android:backgroundTint="#21262D" android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/btnMockGps" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="MOCK" android:textAllCaps="false"
                android:textColor="#C9D1D9" android:backgroundTint="#21262D" android:layout_marginStart="4dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
            <Button android:id="@+id/btnSniffer" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="SNIFFER" android:textAllCaps="false"
                android:textColor="#C9D1D9" android:backgroundTint="#21262D" android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/btnSaveLog" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="СОХРАНИТЬ ЛОГ" android:textAllCaps="false"
                android:textColor="#C9D1D9" android:backgroundTint="#21262D" android:layout_marginStart="4dp"/>
        </LinearLayout>

        <Button android:id="@+id/btnDonation" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="ПОДДЕРЖАТЬ ПРОЕКТ" android:textAllCaps="false"
            android:textColor="#FFFFFF" android:backgroundTint="#8957E5" android:layout_marginTop="14dp"/>
    </LinearLayout>

    <!-- Лог -->
    <ScrollView
        android:id="@+id/logScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:background="#161B22"
        android:padding="8dp">
        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="#8B949E"
            android:textIsSelectable="true" />
    </ScrollView>
</LinearLayout>
