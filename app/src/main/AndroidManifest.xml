<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.ACCESS_MOCK_LOCATION" tools:ignore="MockLocation,ProtectedPermissions"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.INTERNET"/>

    <queries>
        <package android:name="ru.yandex.yandexnavi"/>
        <package android:name="ru.yandex.yandexnavi.inhouse"/>
        <package android:name="ru.yandex.yandexnavi.rustore"/>
        <package android:name="ru.yandex.yandexmaps"/>
        <package android:name="ru.yandex.yandexmaps.beta"/>
        <package android:name="ru.yandex.yandexmaps.inhouse"/>
        <package android:name="ru.yandex.yandexmaps.rustore"/>
        <package android:name="com.ts.car.someip.service"/>
    </queries>

    <application
        android:label="YandexHUD"
        android:allowBackup="false"
        android:theme="@style/AppTheme">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <service
            android:name=".notif.YandexNaviNotificationListener"
            android:label="YandexHUD Notification Bridge"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService"/>
            </intent-filter>
        </service>

        <service
            android:name=".notif.YandexA11yService"
            android:label="YandexHUD Accessibility"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService"/>
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config"/>
        </service>

        <service
            android:name=".bridge.HudForegroundService"
            android:foregroundServiceType="connectedDevice"
            android:exported="false"/>

        <receiver
            android:name=".amap.AmapNaviReceiver"
            android:exported="true">
            <intent-filter android:priority="999">
                <action android:name="AUTONAVI_STANDARD_BROADCAST_SEND"/>
                <action android:name="com.byd.amapservice.ACTION_START_NAVI"/>
                <action android:name="com.byd.amapservice.ACTION_STOP_NAVI"/>
            </intent-filter>
        </receiver>

        <receiver
            android:name=".bridge.HudTestReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.unkwn2.HUD_TEST"/>
            </intent-filter>
        </receiver>

    </application>
</manifest>
